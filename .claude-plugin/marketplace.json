{
  "name": "local-lsps",
  "owner": { "name": "Local" },
  "plugins": [
    {
      "name": "custom-lsps",
      "description": "Custom LSP servers for Bash, SQL, YAML, CSS, HTML, TypeScript, and PowerShell",
      "version": "1.0.0",
      "author": { "name": "Local" },
      "source": "./plugins/custom-lsps",
      "category": "development",
      "strict": false,
      "lspServers": {
        "bash": {
          "command": "node.exe",
          "args": ["C:\\Users\\LI\\AppData\\Roaming\\npm\\node_modules\\bash-language-server\\out\\cli.js", "start"],
          "extensionToLanguage": {
            ".sh": "shellscript",
            ".bash": "shellscript"
          },
          "transport": "stdio",
          "maxRestarts": 3
        },
        "sql": {
          "command": "node.exe",
          "args": ["C:\\Users\\LI\\AppData\\Roaming\\npm\\node_modules\\sql-language-server\\dist\\bin\\cli.js", "up", "--method", "stdio"],
          "extensionToLanguage": {
            ".sql": "sql"
          },
          "transport": "stdio",
          "maxRestarts": 3
        },
        "yaml": {
          "command": "node.exe",
          "args": ["C:\\Users\\LI\\AppData\\Roaming\\npm\\node_modules\\yaml-language-server\\out\\server\\src\\server.js", "--stdio"],
          "extensionToLanguage": {
            ".yml": "yaml",
            ".yaml": "yaml"
          },
          "transport": "stdio",
          "maxRestarts": 3
        },
        "css": {
          "command": "node.exe",
          "args": ["C:\\Users\\LI\\AppData\\Roaming\\npm\\node_modules\\@zed-industries\\vscode-langservers-extracted\\bin\\vscode-css-language-server", "--stdio"],
          "extensionToLanguage": {
            ".css": "css",
            ".scss": "scss",
            ".sass": "sass",
            ".less": "less"
          },
          "transport": "stdio",
          "maxRestarts": 3
        },
        "html": {
          "command": "node.exe",
          "args": ["C:\\Users\\LI\\AppData\\Roaming\\npm\\node_modules\\@zed-industries\\vscode-langservers-extracted\\bin\\vscode-html-language-server", "--stdio"],
          "extensionToLanguage": {
            ".html": "html",
            ".htm": "html"
          },
          "transport": "stdio",
          "maxRestarts": 3
        },
        "typescript": {
          "command": "node.exe",
          "args": ["C:\\Users\\LI\\AppData\\Roaming\\npm\\node_modules\\@vtsls\\language-server\\bin\\vtsls.js", "--stdio"],
          "extensionToLanguage": {
            ".ts": "typescript",
            ".tsx": "typescriptreact",
            ".js": "javascript",
            ".jsx": "javascriptreact",
            ".mjs": "javascript",
            ".cjs": "javascript"
          },
          "transport": "stdio",
          "maxRestarts": 3
        },
        "powershell": {
          "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
          "args": [
            "-NoLogo",
            "-NoProfile",
            "-NonInteractive",
            "-ExecutionPolicy", "Bypass",
            "-Command",
            "$m = Get-Module -ListAvailable PowerShellEditorServices 2>$null | Sort-Object Version -Descending | Select-Object -First 1; if (-not $m) { throw 'PowerShellEditorServices is not installed. Run: Install-Module -Name PowerShellEditorServices -Scope CurrentUser' }; Import-Module $m.Path 3>$null 4>$null 5>$null 6>$null; Start-EditorServices -HostName 'Claude Code' -HostProfileId 'ClaudeCode' -HostVersion '1.0.0' -Stdio -BundledModulesPath (Split-Path $m.Path) -LogPath 'C:\\Users\\LI\\.claude\\pses-cc.log' -LogLevel 'Normal'"
          ],
          "extensionToLanguage": {
            ".ps1": "powershell",
            ".psm1": "powershell",
            ".psd1": "powershell"
          },
          "transport": "stdio",
          "startupTimeout": 120000,
          "shutdownTimeout": 20000,
          "maxRestarts": 3
        }
      }
    }
  ]
}
